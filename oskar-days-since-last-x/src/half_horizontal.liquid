{% if mode == 'meme' %}
<div class="layout layout--col layout--center layout--stretch">
  <img class="image image-dither" src="{{ meme_image_url }}">
</div>
{% else %}
<div class="layout layout--col layout--center gap">
  <span class="label label--medium">It has been</span>
  <span class="value value--mega" data-fit-value="true">{{ display_days }}</span>
  <span class="label label--medium">days since {{ display_label }}</span>
</div>
{% endif %}

<div class="title_bar">
  {{ title_bar_icon }}
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
  <span class="instance">{% if mode == 'meme' %}Meme of the Week{% else %}Days Since Last X{% endif %}</span>
</div>
